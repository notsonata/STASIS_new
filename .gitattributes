# Set line endings
* text=auto

# Maven wrapper
/mvnw text eol=lf
*.cmd text eol=crlf

# Binary files
*.jar binary
*.war binary
*.ear binary
*.zip binary
*.tar.gz binary
*.tgz binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Scripts should be executable
*.sh text eol=lf
build-docker.sh text eol=lf
health-check.sh text eol=lf

# Windows batch files
*.bat text eol=crlf

# Source code
*.java text
*.js text
*.jsx text
*.ts text
*.tsx text
*.css text
*.scss text
*.html text
*.xml text
*.json text
*.yml text
*.yaml text
*.md text
*.properties text

# Docker files
Dockerfile text
docker-compose.yml text
.dockerignore text
